{
  "windows": {
    "defaultVersion": "7.1.1",
    "recommendedVersion": "7.1.1",
    "supportedVersions": {
      "7.1.1": {
        "url": "https://www.gyan.dev/ffmpeg/builds/ffmpeg-release-essentials.zip",
        "description": "推奨バージョン - 最新安定版、最高のパフォーマンス",
        "stability": "recommended"
      },
      "7.0.2": {
        "url": "https://github.com/GyanD/codexffmpeg/releases/download/7.0.2/ffmpeg-7.0.2-essentials_build.zip",
        "description": "フォールバック版 - 7.1.1で問題がある場合のみ使用",
        "stability": "stable"
      }
    },
    "downloadSettings": {
      "timeout": 300,
      "retryCount": 3,
      "userAgent": "PowerShell/VideoMerger"
    },
    "paths": {
      "tempDir": "temp",
      "ffmpegDir": "ffmpeg",
      "backupDir": "ffmpeg-backup"
    }
  },
  "linux": {
    "installMethod": "apt",
    "package": "ffmpeg",
    "minimumVersion": "4.4",
    "recommendedVersion": "6.0",
    "supportedVersions": {
      "Ubuntu 22.04 LTS": {
        "version": "4.4.2",
        "description": "apt 提供バージョン - 最低サポート対象",
        "stability": "minimum"
      },
      "Ubuntu 24.04 LTS": {
        "version": "6.1.1",
        "description": "apt 提供バージョン - 推奨",
        "stability": "recommended"
      }
    },
    "binaries": ["ffmpeg", "ffprobe"],
    "setupScript": "scripts/setup-ffmpeg.sh"
  }
}
