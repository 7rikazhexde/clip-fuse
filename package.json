{
  "name": "clip-fuse",
  "version": "0.0.3",
  "description": "ClipFuse: A simple video merging app with drag & drop and sorting",
  "main": "out/main/index.js",
  "author": "7rikazhexde <33836132+7rikazhexde@users.noreply.github.com>",
  "engines": {
    "node": ">=20.15.1"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "start": "electron-vite preview",
    "build": "electron-vite build && electron-builder",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "lint": "eslint src",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "build:electron": "electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "prepare": "husky"
  },
  "dependencies": {
    "electron-log": "^5.4.4",
    "fluent-ffmpeg": "^2.1.3",
    "sortablejs": "^1.15.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/node": "^25.9.1",
    "@types/sortablejs": "^1.15.9",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.59.4",
    "@vitest/coverage-v8": "^4.1.10",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "eslint": "^10.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "markdownlint-cli": "^0.49.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "lint-staged": {
    "*.ts": "eslint --fix",
    "*.md": "markdownlint --fix"
  },
  "build": {
    "appId": "com.clipfuse.app",
    "productName": "Clip Fuse",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*"
    ],
    "extraResources": [
      {
        "from": "ffmpeg",
        "to": "ffmpeg"
      }
    ],
    "asar": true,
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.utilities"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility",
      "icon": "icon.png"
    },
    "deb": {
      "depends": [
        "libnotify4",
        "xdg-utils",
        "fonts-noto-color-emoji"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
